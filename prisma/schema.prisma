generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  
  accounts      Account[]
  sessions      Session[]

  profile         Profile?
  businessProfile BusinessProfile?
  dailyPlans      DailyPlan[]
  growthPlans     GrowthPlan[]
  dailySubmissions DailySubmission[]
}

model Profile {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @unique @db.ObjectId
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  full_name        String?
  avatar_url       String?
  trial_start_date DateTime?
  trial_end_date   DateTime?
  is_trial_active  Boolean   @default(false)
  is_subscribed    Boolean   @default(false)
}

model BusinessProfile {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @unique @db.ObjectId
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business_name     String?
  industry          String?
  description       String?
  current_stage     String?
  target_audience   String?
  biggest_challenge String?
  current_channels  String[]  @default([])
  monthly_budget    String?
  revenue_goal      String?
}

model GrowthPlan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String?
  is_current Boolean  @default(false)
  createdAt  DateTime @default(now())

  dailyPlans DailyPlan[]
}

model DailyPlan {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  day_number      Int
  growth_plan_id  String      @db.ObjectId
  growthPlan      GrowthPlan  @relation(fields: [growth_plan_id], references: [id], onDelete: Cascade)
  content         String?
  is_unlocked     Boolean     @default(false)
  unlocked_at     DateTime?
  first_opened_at DateTime?
  createdAt       DateTime    @default(now())

  @@unique([userId, day_number])
}

model DailySubmission {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @db.ObjectId
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day_number            Int
  completed_main_task   String?
  what_i_did            String?
  results_noticed       String?
  blockers              String?
  confidence_rating     Int?
  help_needed_tomorrow  String?
  createdAt             DateTime @default(now())

  @@unique([userId, day_number])
}

// NextAuth standard models
model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.String
  access_token       String?  @db.String
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.String
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  tokenHash String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
